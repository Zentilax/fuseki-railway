@prefix :        <#> .
@prefix fuseki:  <http://jena.apache.org/fuseki#> .
@prefix rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix tdb2:    <http://jena.apache.org/2016/tdb#> .
@prefix ja:      <http://jena.hpl.hp.com/2005/11/Assembler#> .

# Root object of the configuration
[] rdf:type fuseki:Server ;
   fuseki:services (
     <#service_german_food>
   ) .

# ==== SERVICE DEFINITION =================================================
# This defines the service and points it to the inference model.

<#service_german_food> rdf:type fuseki:Service ;
    fuseki:name "german-food" ;
    fuseki:serviceQuery "query" ;
    fuseki:serviceUpdate "update" ;
    fuseki:serviceReadWriteGraphStore "data" ;
    # CRITICAL CHANGE: Point the service to the inference model below
    fuseki:dataset <#inferred_dataset> .

# ==== INFERENCE MODEL ====================================================
# This wraps the actual database with a reasoner.

<#inferred_dataset> rdf:type ja:InfModel ;
    # Use the OWL Micro reasoner
    ja:reasonerURL <http://jena.hpl.hp.com/2003/OWLFBRuleReasoner> ;
    # Specify which database to apply the reasoner to
    ja:baseModel <#tdb_dataset_german_food> .

# ==== DATABASE DEFINITION ===============================================
# This is your original TDB2 database definition.

<#tdb_dataset_german_food> rdf:type tdb2:DatasetTDB2 ;
    tdb2:location "german-food" ;
    tdb2:unionDefaultGraph true .
